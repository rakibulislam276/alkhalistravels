# ==============================================================
# .htaccess — Al Khalis Tours and Travels
# Apache: SEO Redirects · Speed · Security · Core Web Vitals
# ==============================================================

Options -Indexes -MultiViews
ServerSignature Off

# ── 1. HTTPS + WWW CANONICAL ──────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force www
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove trailing slash (except root)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^ %1 [L,R=301]
</IfModule>

# ── 2. CUSTOM ERROR PAGES ─────────────────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html
ErrorDocument 403 /403.html

# ── 3. GZIP / BROTLI COMPRESSION ─────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json application/xml
  AddOutputFilterByType DEFLATE text/xml text/plain image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ── 4. BROWSER CACHE — Core Web Vitals ───────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                    "access plus 1 hour"
  ExpiresByType text/css                     "access plus 1 year"
  ExpiresByType application/javascript       "access plus 1 year"
  ExpiresByType text/javascript              "access plus 1 year"
  ExpiresByType image/png                    "access plus 1 year"
  ExpiresByType image/jpeg                   "access plus 1 year"
  ExpiresByType image/webp                   "access plus 1 year"
  ExpiresByType image/svg+xml                "access plus 1 year"
  ExpiresByType image/x-icon                 "access plus 1 year"
  ExpiresByType font/woff2                   "access plus 1 year"
  ExpiresByType font/woff                    "access plus 1 year"
  ExpiresByType application/manifest+json    "access plus 1 week"
  ExpiresByType application/xml              "access plus 1 day"
  ExpiresDefault                             "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2?|png|jpe?g|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  <FilesMatch "sitemap.*\.xml$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# ── 5. SECURITY HEADERS ───────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  # Uncomment after HTTPS confirmed stable:
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://www.googletagmanager.com https://connect.facebook.net https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://www.google.com; connect-src 'self' https://www.google-analytics.com https://api.exchangerate-api.com; object-src 'none'; base-uri 'self';"
</IfModule>

# ── 6. BLOCK BAD BOTS ─────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (SemrushBot|AhrefsBot|MJ12bot|DotBot|GPTBot|CCBot|claudebot|PetalBot|DataForSeoBot) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ── 7. BLOCK SENSITIVE FILES ──────────────────────────────────
<FilesMatch "(^\.htaccess|\.env|\.git|composer\.json|package\.json)">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ── 8. MIME TYPES ─────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType application/json .json
</IfModule>

# ── 9. KEEP-ALIVE ─────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# ── 10. REMOVE ETAG ───────────────────────────────────────────
FileETag None
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
